---
import type { CollectionEntry } from 'astro:content';
const { book: b } = Astro.props;
---

<article class="card">
  <a href={`/books/${b.id}/`}>
    {b.data.coverImage ? (
      <img class="card-image" src={b.data.coverImage} alt={b.data.title} loading="lazy" style="object-fit:contain; background:#f5f5f0;" />
    ) : (
      <div class="card-image-placeholder">{b.data.title[0]}</div>
    )}
    <div class="card-body">
      <h3 class="card-title">{b.data.title}</h3>
      <div class="card-meta">
        <span>{b.data.author}</span>
      </div>
      <div class="tag-list">
        <span class={`reading-path ${b.data.readingPath}`}>{b.data.readingPath === 'beginner' ? '入门' : b.data.readingPath === 'intermediate' ? '进阶' : '深度'}</span>
        {b.data.tags.slice(0, 2).map(t => <span class="tag">{t}</span>)}
      </div>
    </div>
  </a>
</article>
