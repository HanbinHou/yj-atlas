---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import CaseCard from '../components/CaseCard.astro';
import MaterialCard from '../components/MaterialCard.astro';
import BookCard from '../components/BookCard.astro';

const cases = (await getCollection('cases')).slice(0, 8);
const materials = (await getCollection('materials')).slice(0, 8);
const books = (await getCollection('books')).slice(0, 8);
---

<BaseLayout
  title="咏迹探所"
  description="YJ Atlas 咏迹探所 — 面向建筑学生的知识库：案例研究、材料手册、阅读书目"
>
  <section class="hero">
    <h1 class="hero-title">
      <span class="hero-accent">YJ</span> Atlas
    </h1>
    <p class="hero-subtitle">
      咏迹探所 — 案例 · 材料 · 书目
    </p>
  </section>

  <div class="container">
    <section class="home-section" style="max-width: 640px; margin: 0 auto var(--space-xl);">
      <form action="/search/" method="GET" style="display: flex; gap: var(--space-sm);">
        <input
          type="text"
          name="q"
          class="search-input"
          placeholder="搜索建筑师、材料、建筑类型、书名……"
          style="margin-bottom: 0;"
        />
        <button type="submit" class="btn-search">搜索</button>
      </form>
    </section>

    <section class="home-section">
      <div class="home-section-header">
        <h2>近期案例</h2>
        <a href="/cases/">全部案例 →</a>
      </div>
      <div class="card-grid">
        {cases.map(c => <CaseCard case={c} />)}
      </div>
    </section>

    <section class="home-section">
      <div class="home-section-header">
        <h2>材料手册</h2>
        <a href="/materials/">全部材料 →</a>
      </div>
      <div class="card-grid">
        {materials.map(m => <MaterialCard material={m} />)}
      </div>
    </section>

    <section class="home-section">
      <div class="home-section-header">
        <h2>阅读书目</h2>
        <a href="/books/">全部书目 →</a>
      </div>
      <div class="card-grid">
        {books.map(b => <BookCard book={b} />)}
      </div>
    </section>
  </div>
</BaseLayout>
