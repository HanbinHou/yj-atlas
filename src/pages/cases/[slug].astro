---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  return cases.map(c => ({ params: { slug: c.id } }));
}

const { slug } = Astro.params;
const cases = await getCollection('cases');
const case_ = cases.find(c => c.id === slug)!;

// Collect all unique filter values for this case
const materials = await getCollection('materials');
const relatedMaterials = materials.filter(m =>
  case_.data.materials.includes(m.data.title)
);
---

<BaseLayout title={case_.data.title} description={case_.data.description}>
  <article class="content-container" style="padding-top: var(--space-xl);">
    <header class="detail-header">
      <h1 class="detail-title">{case_.data.title}</h1>

      <div class="detail-meta">
        <div class="detail-meta-item">
          <span class="detail-meta-label">建筑师</span>
          <span>{case_.data.architect}</span>
        </div>
        <div class="detail-meta-item">
          <span class="detail-meta-label">年份</span>
          <span>{case_.data.year}</span>
        </div>
        <div class="detail-meta-item">
          <span class="detail-meta-label">地点</span>
          <span>{case_.data.location}</span>
        </div>
        <div class="detail-meta-item">
          <span class="detail-meta-label">类型</span>
          <span>{case_.data.type}</span>
        </div>
        {case_.data.status && (
          <div class="detail-meta-item">
            <span class="detail-meta-label">状态</span>
            <span>{case_.data.status}</span>
          </div>
        )}
      </div>

      <div class="tag-list" style="margin-top: var(--space-md);">
        <span class="tag">{case_.data.type}</span>
        {case_.data.materials.map(m => <span class="tag">{m}</span>)}
        {case_.data.tags.map(t => <span class="tag">{t}</span>)}
      </div>
    </header>

    {case_.data.images.length > 0 && (
      <img class="detail-image lightbox-trigger" src={case_.data.images[0]} alt={case_.data.title} data-index="0" />
    )}

    <div class="detail-content" set:html={case_.rendered?.html || case_.body || ''} />

    {case_.data.images.length > 1 && (
      <section style="margin-top: var(--space-xl);">
        <h3 style="margin-bottom: var(--space-md);">更多图片</h3>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-md);">
          {case_.data.images.slice(1).map((img, i) => (
            <img src={img} alt={case_.data.title} class="lightbox-trigger" data-index={i + 1} style="border: 1px solid var(--color-border); cursor: pointer;" loading="lazy" />
          ))}
        </div>
      </section>
    )}

    {relatedMaterials.length > 0 && (
      <section class="related-section">
        <h3>相关材料</h3>
        <ul class="related-list">
          {relatedMaterials.map(m => (
            <li><a href={`/materials/${m.id}/`}>{m.data.title}</a></li>
          ))}
        </ul>
      </section>
    )}

    <!-- Lightbox -->
    <div id="lightbox" class="lightbox-overlay" data-images={JSON.stringify(case_.data.images)}>
      <span class="lightbox-close">&times;</span>
      <span class="lightbox-arrow lightbox-prev">&lsaquo;</span>
      <span class="lightbox-arrow lightbox-next">&rsaquo;</span>
      <img id="lightbox-img" class="lightbox-img" src="" alt="" />
    </div>
  </article>
</BaseLayout>

<script>
  const allImages = JSON.parse(document.getElementById('lightbox').dataset.images);
  let currentIdx = 0;
  const triggers = document.querySelectorAll('.lightbox-trigger');
  const overlay = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const prevBtn = document.querySelector('.lightbox-prev');
  const nextBtn = document.querySelector('.lightbox-next');

  function showImage(idx) {
    currentIdx = idx;
    lightboxImg.src = allImages[idx];
    prevBtn.style.visibility = idx > 0 ? 'visible' : 'hidden';
    nextBtn.style.visibility = idx < allImages.length - 1 ? 'visible' : 'hidden';
  }

  function openLightbox(idx) {
    showImage(idx);
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    overlay.classList.remove('active');
    document.body.style.overflow = '';
  }

  triggers.forEach(img => {
    img.style.cursor = 'pointer';
    img.addEventListener('click', () => {
      openLightbox(parseInt(img.dataset.index) || 0);
    });
  });

  prevBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    if (currentIdx > 0) showImage(currentIdx - 1);
  });
  nextBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    if (currentIdx < allImages.length - 1) showImage(currentIdx + 1);
  });
  overlay.querySelector('.lightbox-close').addEventListener('click', closeLightbox);
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft' && overlay.classList.contains('active') && currentIdx > 0) showImage(currentIdx - 1);
    if (e.key === 'ArrowRight' && overlay.classList.contains('active') && currentIdx < allImages.length - 1) showImage(currentIdx + 1);
  });
</script>

<style>
  .lightbox-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,0.93); z-index: 9999;
    align-items: center; justify-content: center;
  }
  .lightbox-overlay.active { display: flex; }
  .lightbox-img {
    max-width: 92vw; max-height: 92vh;
    object-fit: contain; cursor: default;
    user-select: none; -webkit-user-select: none;
  }
  .lightbox-close {
    position: absolute; top: 1.2rem; right: 1.6rem;
    color: #fff; font-size: 2rem; cursor: pointer;
    z-index: 10000; line-height: 1; opacity: 0.5;
    transition: opacity 0.2s; font-weight: 200;
  }
  .lightbox-close:hover { opacity: 0.9; }
  .lightbox-arrow {
    position: absolute; top: 50%; transform: translateY(-50%);
    color: #fff; font-size: 3rem; font-weight: 200;
    cursor: pointer; z-index: 10000; opacity: 0.4;
    transition: opacity 0.2s; line-height: 1;
    padding: 1rem; user-select: none;
  }
  .lightbox-arrow:hover { opacity: 0.85; }
  .lightbox-prev { left: 0.5rem; }
  .lightbox-next { right: 0.5rem; }
</style>
